{
    "name": "gupalo/symfony-response-helpers",
    "description": "Symfony Response Helpers",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "symfony/http-foundation": "^8.0",
        "gupalo/dateutils": "^1.20"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "Gupalo\\SymfonyResponseHelpers\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Gupalo\\SymfonyResponseHelpers\\Tests\\": "tests/"
        }
    }
}
